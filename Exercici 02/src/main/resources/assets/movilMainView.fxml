<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?> <?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<BorderPane fx:id="rootNode" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/24.0.1" fx:controller="com.project.CtrlMovilMain">
    
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <top>
        <StackPane styleClass="header-movil">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Nintendo DB" />
        </StackPane>
    </top>

    <center>
        <ListView fx:id="menuListView" onMouseClicked="#onMenuClicked" />
    </center>
    
</BorderPane>