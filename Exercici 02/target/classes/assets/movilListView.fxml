<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.SVGPath?>
<?import java.net.URL?> <BorderPane fx:id="rootNode" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/24.0.1" fx:controller="com.project.CtrlMovilLista">
    
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="header-movil">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Button fx:id="btnVolverMenu" onAction="#onVolverMenu" styleClass="boton-volver">
                <graphic>
                    <SVGPath content="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" styleClass="icono-volver" />
                </graphic>
            </Button>
            <Label fx:id="listTitle" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Título de Lista" />
        </HBox>
    </top>

    <center>
        <ListView fx:id="itemListView" onMouseClicked="#onListItemClicked" />
    </center>

</BorderPane>